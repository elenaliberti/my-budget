{
  "name": "my-budget",
  "version": "1.0.0",
  "description": "Personal budget tracker with predictions & simulation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.mybudget.app",
    "productName": "My Budget",
    "mac": { "category": "public.app-category.finance", "icon": "assets/icon.icns" },
    "directories": { "output": "dist" },
    "files": ["**/*", "!dist/**"]
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
